@model comp2139.Models.Project

@{
    ViewData["Title"] = "Edit Project"; //sets the title of the view to "Edit Project"
}

<h2>Edit Project</h2>

<form asp-action="Edit" method="post">
    
    <!-- Hidden field to ensure the ProjectId (primary key) is included in the form submission
    link in the data to correct record i  the database -->
    @Html.HiddenFor(model => model.ProjectId)

    <div class="form-group">
        <label asp-for="Name" class="control-label"></label>
        <input asp-for="Name" class="form-control"/>
        <span asp-validation-for="Name" class="text-danger"></span>

    </div>

    <div class="form-group">
        <label asp-for="Description" class="control-label"></label>
        <textarea asp-for="Description" class="form-control"></textarea>
        <span asp-validation-for="Description" class="text-danger"></span>

    </div>
    <!-- Include other form fields here -->

    <div class="form-group">
        <input type="submit" value="Save" class="btn btn-primary"/>
        <a asp-action="Index" btn="btn btn-secondary">Cancel</a>
    </div>
</form>



@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}